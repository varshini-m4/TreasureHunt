{
  "expo": {
    "name": "birthday-treasure-hunt",
    "slug": "birthday-treasure-hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "birthdaytreasurehunt",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/expo.icon/Assets/grid.png",
        "backgroundImage": "./assets/expo.icon/Assets/grid.png",
        "monochromeImage": "./assets/expo.icon/Assets/grid.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.birthdaytreasurehunt"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo.icon/Assets/grid.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/expo.icon/Assets/grid.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}