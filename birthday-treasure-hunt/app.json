{
  "expo": {
    "name": "Birthday Treasure Hunt",
    "slug": "birthday-treasure-hunt",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "birthdaytreasurehunt",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/expo.icon/Assets/explorer_boy.png",
        "backgroundImage": "./assets/expo.icon/Assets/explorer_boy.png",
        "monochromeImage": "./assets/expo.icon/Assets/explorer_boy.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.birthdaytreasurehunt"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo.icon/Assets/grid.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/expo.icon/Assets/grid.png",
          "imageWidth": 76
        }
      ],
      "expo-audio",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "abb6c838-7e47-4e83-b4b7-c1e16960f84a"
      }
    }
  }
}